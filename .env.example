# =============================================================================
# GAZNGER MOBILE — ENVIRONMENT VARIABLES
# Only EXPO_PUBLIC_* vars are accessible in app code.
#
# FILE STRATEGY:
#   .env            → production values (committed, no secrets)
#   .env.local      → local dev override (NOT committed — add to .gitignore)
#   .env.production → EAS production build overrides (NOT committed)
#
# Expo loads files in this order (first match wins):
#   development:  .env.local → .env
#   EAS prod:     .env.production → .env
#
# LOCAL DEV SETUP:
#   1. Copy this file to .env.local
#   2. Set EXPO_PUBLIC_BASE_URL to your machine's LAN IP:
#        Windows: run `ipconfig` → IPv4 Address under your Wi-Fi adapter
#        Mac/Linux: run `ifconfig en0 | grep inet`
#        Example: http://172.20.10.7:5000
#   3. Make sure your phone and PC are on the same Wi-Fi network
# =============================================================================

# URL of the Gaznger backend API
# Production:
EXPO_PUBLIC_BASE_URL=https://your-backend.onrender.com
# Local dev example (copy to .env.local and replace with your IP):
# EXPO_PUBLIC_BASE_URL=http://192.168.x.x:5000

# Google Maps API key (configured in app.config.js for iOS + Android)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
